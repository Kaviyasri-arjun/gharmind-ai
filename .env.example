# GHARMIND AI — Environment Variables Template
# Copy to .env and fill in your values
# NEVER commit the actual .env file to version control

# ─── Application ─────────────────────────────────────────────────────
APP_ENV=development                   # development | staging | production
APP_NAME=GHARMIND AI
APP_VERSION=1.0.0
DEBUG=true

# ─── API ────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,https://app.gharmind.in
SECRET_KEY=your-secret-key-here-replace-in-production

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://gharmind:password@localhost:5432/gharmind
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=300

# ─── AWS ─────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ─── AWS Bedrock ─────────────────────────────────────────────────────
BEDROCK_REGION=ap-south-1             # or us-east-1 if ap-south-1 unavailable
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_CLAUDE_HAIKU_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_TITAN_EMBED_MODEL_ID=amazon.titan-embed-text-v1
BEDROCK_MAX_RETRIES=3
BEDROCK_TIMEOUT_SECONDS=30

# ─── AWS Cognito ─────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
COGNITO_APP_CLIENT_ID=your-app-client-id
COGNITO_REGION=ap-south-1

# ─── Twin Engine ─────────────────────────────────────────────────────
TWIN_TICK_INTERVAL_SECONDS=60
PREDICTION_INTERVAL_SECONDS=300       # 5 minutes
PATTERN_ANALYSIS_CRON=0 2 * * 0      # Weekly Sunday 2am IST
HISTORICAL_SIM_DAYS=30                # Days to simulate on onboarding

# ─── Feature Flags ────────────────────────────────────────────────────
ENABLE_STREAMING_CHAT=true
ENABLE_WHATIF_SIMULATOR=true
ENABLE_PATTERN_LEARNING=true
ENABLE_WHATSAPP_ALERTS=false          # Future feature

# ─── Frontend (Next.js) ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_APP_NAME=GHARMIND AI
NEXT_PUBLIC_DEFAULT_LANGUAGE=hinglish

# ─── Monitoring ──────────────────────────────────────────────────────
SENTRY_DSN=                           # Optional error tracking
CLOUDWATCH_LOG_GROUP=/gharmind/local
