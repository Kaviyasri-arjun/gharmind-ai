# GHARMIND AI Backend — Environment Variables
# Copy to .env and adjust values for your local setup.
# NEVER commit .env to version control.

# ── Application ────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars!!

# ── Database (PostgreSQL 16 + pgvector) ────────────────────────────
DATABASE_URL=postgresql+asyncpg://gharmind:devpassword@localhost:5432/gharmind

# ── Redis ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS Bedrock ────────────────────────────────────────────────────
# For local dev without AWS, set BEDROCK_MOCK_RESPONSES=true
BEDROCK_MOCK_RESPONSES=true
BEDROCK_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Auth ───────────────────────────────────────────────────────────
# SKIP_AUTH=true bypasses JWT — set false in production
SKIP_AUTH=true
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
